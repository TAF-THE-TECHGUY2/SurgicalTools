APP_NAME="Surgical Devices ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Production target is PostgreSQL. For a zero-dependency local run you may set
# DB_CONNECTION=sqlite (and `touch database/database.sqlite`). The schema is
# written to be portable across both engines.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=surgical_erp
DB_USERNAME=surgical
DB_PASSWORD=secret

# ---------------------------------------------------------------------------
# Session / cache / queue
# ---------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Mail  (local: MailHog on :1025 — see docker-compose)
# ---------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="no-reply@surgicaldevices.example"
MAIL_FROM_NAME="${APP_NAME}"

# Distribution lists for transfer / delivery-note PDFs
MAIL_OFFICE_ADDRESS=office@surgicaldevices.example
MAIL_STOCK_CONTROLLER_ADDRESS=stock@surgicaldevices.example
MAIL_INVENTORY_CONTROLLER_ADDRESS=inventory@surgicaldevices.example

# ---------------------------------------------------------------------------
# File storage — S3 compatible (PDFs, signatures, count photos)
# Local dev uses the `local` disk; set FILESYSTEM_DISK=s3 in production.
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=surgical-erp-documents
AWS_USE_PATH_STYLE_ENDPOINT=false
# For MinIO / DigitalOcean Spaces set the endpoint + path style:
# AWS_ENDPOINT=http://127.0.0.1:9000
# AWS_USE_PATH_STYLE_ENDPOINT=true

# ---------------------------------------------------------------------------
# SPA / mobile client (CORS + Sanctum)
# ---------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

# ---------------------------------------------------------------------------
# Domain configuration
# ---------------------------------------------------------------------------
EXPIRY_WARNING_DAYS=90
EXPIRY_HIGH_DAYS=60
EXPIRY_CRITICAL_DAYS=30
LOW_STOCK_DEFAULT_THRESHOLD=5

VITE_APP_NAME="${APP_NAME}"
